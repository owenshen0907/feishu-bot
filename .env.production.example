BOT_PROFILE=production
NODE_ENV=production

# Feishu long connection (required only when you want the bot to actually come online)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BOT_NAME=feishu-bot

# Diagnostic bridge (production, preferred names; legacy SMARTKIT_* aliases are still supported)
DIAGNOSTIC_HTTP_BASE_URL=https://diagnostics.example.com
DIAGNOSTIC_HTTP_TOKEN=
DIAGNOSTIC_HTTP_CALLER=feishu-bot
DIAGNOSTIC_HTTP_TIMEOUT_MS=20000

# Local session store
SESSION_DB_PATH=./data/feishu-bot.sqlite
JOB_POLL_INTERVAL_MS=15000

# Optional local health endpoint
HEALTH_BIND=127.0.0.1
HEALTH_PORT=3179

# Bot-side LLM (default provider: StepFun)
BOT_LLM_PROVIDER=stepfun
BOT_LLM_ENABLED=true
BOT_LLM_API_KEY=
BOT_LLM_BASE_URL=https://api.stepfun.com/v1
BOT_LLM_MODEL=step-3.5-flash
BOT_LLM_TIMEOUT_MS=15000
BOT_VISION_MODEL=step-1o-turbo-vision
BOT_TTS_MODEL=step-tts-2

# Optional standalone chat
BOT_CHAT_ENABLED=true
BOT_CHAT_MEMORY_MESSAGES=16

# Optional abilities
BRAVE_SEARCH_API_KEY=
BOT_CAPABILITY_WEB_SEARCH=false
BOT_CAPABILITY_VOICE_REPLY=false
BOT_CAPABILITY_VISION=false
