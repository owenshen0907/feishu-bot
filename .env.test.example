BOT_PROFILE=test
NODE_ENV=production

# Feishu long connection
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BOT_NAME=smartkit-bot-test

# SmartKit bridge (test)
SMARTKIT_BASE_URL=https://smartkit-test.example.com
SMARTKIT_TOKEN=
SMARTKIT_CALLER=feishu-bot
SMARTKIT_TIMEOUT_MS=20000

# Local session store
SESSION_DB_PATH=./data/feishu-bot-test.sqlite
JOB_POLL_INTERVAL_MS=10000

# Optional local health endpoint
HEALTH_BIND=127.0.0.1
HEALTH_PORT=3179

# Optional bot-side LLM formatting
BOT_LLM_ENABLED=false
BOT_LLM_API_KEY=
BOT_LLM_BASE_URL=https://api.openai.com/v1
BOT_LLM_MODEL=gpt-4.1-mini
BOT_LLM_TIMEOUT_MS=15000

# Optional standalone chat
BOT_CHAT_ENABLED=true
BOT_CHAT_MEMORY_MESSAGES=16
